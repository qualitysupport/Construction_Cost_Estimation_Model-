  list(name = "Site Plan",   low = 500,   high = 500),
  list(name = "Drawing",     low = 2000,  high = 2000),
  list(name = "Permits",     low = 15000, high = 20000),
  list(name = "Foundation",  low = 50000, high = 70000),
  list(name = "Framing",     low = 10000, high = 40000),
  list(name = "Siding",      low = 10000, high = 30000),
  list(name = "Wiring",      low = 6000,  high = 15000),
  list(name = "Plumbing",    low = 5000,  high = 16000),
  list(name = "HVAC",        low = 5000,  high = 15000),
  list(name = "Windows",     low = 5000,  high = 15000),
  list(name = "Doors",       low = 5000,  high = 8000),
  list(name = "Gutters",     low = 2000,  high = 7000),
  list(name = "Roof",        low = 10000, high = 35000),
  list(name = "Insulation",  low = 5000,  high = 10000),
  list(name = "Drywall",     low = 5000,  high = 30000),
  list(name = "Trim",        low = 500,   high = 15000),
  list(name = "Paint",       low = 100,   high = 500),
  list(name = "Flooring",    low = 5000,  high = 15000),
  list(name = "Kitchen",     low = 8000,  high = 12000),
  list(name = "Bathrooms",   low = 3000,  high = 6000),
  list(name = "Lighting",    low = 500,   high = 1000),
  list(name = "Driveway",    low = 5000,  high = 10000),
  list(name = "Deck",        low = 10000, high = 20000),
  list(name = "Landscape",   low = 2000,  high = 5000)
