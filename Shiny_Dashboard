      p("GUM Method — Rectangular Distributions",
        style = "color: #444444; font-size: 14px; margin-top: 0;")
    )
  ),
  
  sidebarLayout(
    sidebarPanel(
      width = 3,
      
      # Coverage factor
      h4("Coverage Factor", style = "color: #1F3864; font-weight: bold;"),
      sliderInput("k", "k (confidence level)",
                  min = 1, max = 3, value = 2, step = 0.5),
      helpText("k=1 (~68%)  k=2 (~95%)  k=3 (~99%)"),
      
      hr(),
      
      # Component toggles and inputs
      h4("Components", style = "color: #1F3864; font-weight: bold;"),
      p("Toggle, adjust low and high values for each component.",
        style = "font-size: 12px; color: #666;"),
      
      # Dynamically generate inputs for each component
      lapply(seq_len(n), function(i) {
        comp <- defaults[[i]]
        div(
          style = "border-bottom: 1px solid #eee; padding: 8px 0;",
          checkboxInput(paste0("include_", i), comp$name, value = TRUE),
          conditionalPanel(
            condition = paste0("input.include_", i, " == true"),
            fluidRow(
              column(6,
                     numericInput(paste0("low_", i), "Low ($)",
                                  value = comp$low, min = 0, step = 500)
              ),
