# ============================================================
# Server
# ============================================================

server <- function(input, output, session) {
  
  # Reactive: compute results from current inputs
  results <- reactive({
    components <- lapply(seq_len(n), function(i) {
      if (!isTRUE(input[[paste0("include_", i)]])) return(NULL)
      lo   <- input[[paste0("low_",  i)]]
      hi   <- input[[paste0("high_", i)]]
      if (is.null(lo) || is.null(hi) || hi < lo) return(NULL)
      list(
        name        = defaults[[i]]$name,
        low         = lo,
        high        = hi,
        mid         = (lo + hi) / 2,
        uncertainty = (hi - lo) / sqrt(12)
      )
    })
    components <- Filter(Negate(is.null), components)
    
    if (length(components) == 0) return(NULL)
    
    u_values   <- sapply(components, `[[`, "uncertainty")
    mid_values <- sapply(components, `[[`, "mid")
    names_vec  <- sapply(components, `[[`, "name")
    
    u_combined  <- sqrt(sum(u_values^2))
    total_cost  <- sum(mid_values)
    k           <- input$k
    U_expanded  <- k * u_combined
    
    list(
      components  = components,
      u_values    = u_values,
      names_vec   = names_vec,
      u_combined  = u_combined,
      total_cost  = total_cost,
      k           = k,
      U_expanded  = U_expanded,
      lower       = total_cost - U_expanded,
      upper       = total_cost + U_expanded
    )
  })
  
  # Summary outputs
  fmt <- function(x) paste0("$", formatC(round(x), format="d", big.mark=","))
  
  output$total_cost   <- renderText({ req(results()); fmt(results()$total_cost) })
  output$expanded_u   <- renderText({ req(results()); paste0("\u00B1", fmt(results()$U_expanded)) })
  output$lower_bound  <- renderText({ req(results()); fmt(results()$lower) })
  output$upper_bound  <- renderText({ req(results()); fmt(results()$upper) })
  
  # Tornado chart
  output$tornado <- renderPlot({
    req(results())
    r <- results()
    
    df <- data.frame(
      name        = r$names_vec,
      uncertainty = r$u_values
    )
    df <- df[order(df$uncertainty), ]
    df$name <- factor(df$name, levels = df$name)
    
    ggplot(df, aes(x = uncertainty, y = name)) +
      geom_bar(stat = "identity", fill = "#2E5F8A", alpha = 0.8) +
      geom_text(aes(label = paste0("$", formatC(round(uncertainty), format="d", big.mark=","))),
                hjust = -0.1, size = 3.2, color = "#1F3864") +
      scale_x_continuous(
        labels = scales::dollar_format(),
        expand = expansion(mult = c(0, 0.2))
      ) +
      labs(
        title    = "Uncertainty Contribution by Component",
        subtitle = "Standard uncertainty (1\u03C3) per component — ranked lowest to highest",
        x        = "Standard Uncertainty ($)",
        y        = NULL
      ) +
      theme_minimal(base_size = 12) +
      theme(
        plot.title       = element_text(face = "bold", color = "#1F3864", size = 14),
        plot.subtitle    = element_text(color = "#444444", size = 10),
        panel.grid.minor  = element_blank(),
        panel.grid.major.y = element_blank(),
        axis.text.y      = element_text(size = 10, color = "#1F3864")
      )
  })
  
  # Normal curve
  output$normal_curve <- renderPlot({
    req(results())
    r <- results()
    
    x    <- seq(r$total_cost - 4 * r$u_combined,
                r$total_cost + 4 * r$u_combined,
                length.out = 1000)
    ny   <- dnorm(x, mean = r$total_cost, sd = r$u_combined)
    df   <- data.frame(x = x, y = ny)
    sh   <- subset(df, x >= r$lower & x <= r$upper)
    
    ggplot(df, aes(x = x, y = y)) +
      geom_area(data = sh, aes(x = x, y = y), fill = "#2E5F8A", alpha = 0.3) +
      geom_line(color = "#2E5F8A", linewidth = 1) +
      geom_vline(xintercept = r$total_cost, linetype = "dashed",
                 color = "#1F3864", linewidth = 0.8) +
      geom_vline(xintercept = r$lower, linetype = "dotted",
                 color = "#888888", linewidth = 0.7) +
      geom_vline(xintercept = r$upper, linetype = "dotted",
                 color = "#888888", linewidth = 0.7) +
      annotate("text", x = r$total_cost, y = max(ny) * 1.05,
               label = paste0("Est. Cost\n$", formatC(round(r$total_cost), format="d", big.mark=",")),
               hjust = -0.1, size = 3.5, color = "#1F3864") +
      annotate("text", x = r$lower, y = -max(ny) * 0.05,
               label = paste0("$", formatC(round(r$lower), format="d", big.mark=",")),
               size = 3, color = "#888888", hjust = 0.5) +
      annotate("text", x = r$upper, y = -max(ny) * 0.05,
               label = paste0("$", formatC(round(r$upper), format="d", big.mark=",")),
               size = 3, color = "#888888", hjust = 0.5) +
      annotate("text", x = r$total_cost, y = max(ny) * 0.45,
               label = paste0("k=", r$k, " (~",
                              ifelse(r$k == 1, "68", ifelse(r$k == 2, "95", "99")),
                              "%) Confidence\n\u00B1$",
                              formatC(round(r$U_expanded), format="d", big.mark=",")),
               hjust = -0.1, size = 3.5, color = "#2E5F8A") +
      scale_x_continuous(labels = scales::dollar_format()) +
      labs(
        title    = "How Much Do We Need to Borrow?",
        subtitle = "Combined uncertainty across all active components",
        x        = "Total Estimated Cost ($)",
        y        = "Probability Density"
      ) +
      theme_minimal(base_size = 12) +
      theme(
        plot.title    = element_text(face = "bold", color = "#1F3864", size = 14),
        plot.subtitle = element_text(color = "#444444", size = 10),
        panel.grid.minor = element_blank()
      )
  })
}

# ============================================================
# Run App
# ============================================================

shinyApp(ui = ui, server = server)
