    mainPanel(
      width = 9,
      
      # Summary metrics
      fluidRow(
        column(3,
               div(style = "background: #f5f7fa; border-radius: 8px; padding: 16px; text-align: center;",
                   p("Total Estimated Cost", style = "font-size: 12px; color: #888; margin-bottom: 4px;"),
                   h3(textOutput("total_cost"), style = "color: #1F3864; margin: 0;")
               )
        ),
        column(3,
               div(style = "background: #f5f7fa; border-radius: 8px; padding: 16px; text-align: center;",
                   p("Expanded Uncertainty", style = "font-size: 12px; color: #888; margin-bottom: 4px;"),
                   h3(textOutput("expanded_u"), style = "color: #2E5F8A; margin: 0;")
               )
        ),
        column(3,
               div(style = "background: #f5f7fa; border-radius: 8px; padding: 16px; text-align: center;",
                   p("Lower Bound", style = "font-size: 12px; color: #888; margin-bottom: 4px;"),
                   h3(textOutput("lower_bound"), style = "color: #2E5F8A; margin: 0;")
