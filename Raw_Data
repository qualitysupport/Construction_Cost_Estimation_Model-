cat(sprintf("Component 24 - Landscape:    $%.2f\n", landscape_uncertainty))

# ============================================================
# RSS - Combined Uncertainty (Rectangular Distributions)
# ============================================================

# Standard uncertainty for each component: u = (high - low) / sqrt(12)
u_siteplan    <- siteplan_uncertainty    / sqrt(12)
u_drawing     <- drawing_uncertainty     / sqrt(12)
u_permit      <- permit_uncertainty      / sqrt(12)
u_foundation  <- foundation_uncertainty  / sqrt(12)
u_framing     <- framing_uncertainty     / sqrt(12)
u_siding      <- siding_uncertainty      / sqrt(12)
u_wiring      <- wiring_uncertainty      / sqrt(12)
u_plumbing    <- plumbing_uncertainty    / sqrt(12)
u_hvac        <- hvac_uncertainty        / sqrt(12)
u_windows     <- windows_uncertainty     / sqrt(12)
u_doors       <- doors_uncertainty       / sqrt(12)
u_gutters     <- gutters_uncertainty     / sqrt(12)
u_roof        <- roof_uncertainty        / sqrt(12)
u_insulation  <- insulation_uncertainty  / sqrt(12)
u_drywall     <- drywall_uncertainty     / sqrt(12)
u_trim        <- trim_uncertainty        / sqrt(12)
u_paint       <- paint_uncertainty       / sqrt(12)
u_flooring    <- flooring_uncertainty    / sqrt(12)
u_kitchen     <- kitchen_uncertainty     / sqrt(12)
u_bathrooms   <- bathrooms_uncertainty   / sqrt(12)
u_lighting    <- lighting_uncertainty    / sqrt(12)
u_driveway    <- driveway_uncertainty    / sqrt(12)
u_deck        <- deck_uncertainty        / sqrt(12)
u_landscape   <- landscape_uncertainty   / sqrt(12)

# Combined standard uncertainty (RSS)
u_combined <- sqrt(
  u_siteplan^2 + u_drawing^2 + u_permit^2 + u_foundation^2 +
  u_framing^2 + u_siding^2 + u_wiring^2 + u_plumbing^2 +
  u_hvac^2 + u_windows^2 + u_doors^2 + u_gutters^2 +
  u_roof^2 + u_insulation^2 + u_drywall^2 + u_trim^2 +
  u_paint^2 + u_flooring^2 + u_kitchen^2 + u_bathrooms^2 +
  u_lighting^2 + u_driveway^2 + u_deck^2 + u_landscape^2
)

# Expanded uncertainty (k=2, ~95% confidence)
k <- 2
U_expanded <- k * u_combined

# Total estimated cost (midpoint of each component)
total_cost <- sum(
  (siteplan_low + siteplan_high) / 2,
  (drawing_low + drawing_high) / 2,
  (permit_low + permit_high) / 2,
  (foundation_low + foundation_high) / 2,
  (framing_low + framing_high) / 2,
  (siding_low + siding_high) / 2,
  (wiring_low + wiring_high) / 2,
  (plumbing_low + plumbing_high) / 2,
  (hvac_low + hvac_high) / 2,
  (windows_low + windows_high) / 2,
  (doors_low + doors_high) / 2,
  (gutters_low + gutters_high) / 2,
  (roof_low + roof_high) / 2,
  (insulation_low + insulation_high) / 2,
  (drywall_low + drywall_high) / 2,
  (trim_low + trim_high) / 2,
  (paint_low + paint_high) / 2,
  (flooring_low + flooring_high) / 2,
  (kitchen_low + kitchen_high) / 2,
  (bathrooms_low + bathrooms_high) / 2,
  (lighting_low + lighting_high) / 2,
  (driveway_low + driveway_high) / 2,
  (deck_low + deck_high) / 2,
  (landscape_low + landscape_high) / 2
)

# ============================================================
# Print Results
# ============================================================

cat("\n=== GUM Uncertainty Results ===\n\n")
cat(sprintf("Total Estimated Cost:     $%s\n",   formatC(total_cost,  format="f", digits=2, big.mark=",")))
cat(sprintf("Combined Uncertainty:     $%s\n",   formatC(u_combined,  format="f", digits=2, big.mark=",")))
cat(sprintf("Coverage Factor (k):       %d\n",   k))
cat(sprintf("Expanded Uncertainty:     $%s\n",   formatC(U_expanded,  format="f", digits=2, big.mark=",")))
cat(sprintf("Lower Bound (95%%):        $%s\n",  formatC(total_cost - U_expanded, format="f", digits=2, big.mark=",")))
cat(sprintf("Upper Bound (95%%):        $%s\n",  formatC(total_cost + U_expanded, format="f", digits=2, big.mark=",")))
cat(sprintf("\nWe estimate the house will cost $%s +/- $%s at 95%% confidence.\n",
    formatC(total_cost, format="f", digits=2, big.mark=","),
    formatC(U_expanded, format="f", digits=2, big.mark=",")))
