# Print Component Uncertainties
# ============================================================

cat("=== House Build Cost Uncertainty Summary ===\n\n")
cat(sprintf("Component 1  - Site Plan:    $%.2f\n", siteplan_uncertainty))
cat(sprintf("Component 2  - Drawing:      $%.2f\n", drawing_uncertainty))
cat(sprintf("Component 3  - Permits:      $%.2f\n", permit_uncertainty))
cat(sprintf("Component 4  - Foundation:   $%.2f\n", foundation_uncertainty))
cat(sprintf("Component 5  - Framing:      $%.2f\n", framing_uncertainty))
cat(sprintf("Component 6  - Siding:       $%.2f\n", siding_uncertainty))
cat(sprintf("Component 7  - Wiring:       $%.2f\n", wiring_uncertainty))
cat(sprintf("Component 8  - Plumbing:     $%.2f\n", plumbing_uncertainty))
cat(sprintf("Component 9  - HVAC:         $%.2f\n", hvac_uncertainty))
cat(sprintf("Component 10 - Windows:      $%.2f\n", windows_uncertainty))
cat(sprintf("Component 11 - Doors:        $%.2f\n", doors_uncertainty))
cat(sprintf("Component 12 - Gutters:      $%.2f\n", gutters_uncertainty))
cat(sprintf("Component 13 - Roof:         $%.2f\n", roof_uncertainty))
cat(sprintf("Component 14 - Insulation:   $%.2f\n", insulation_uncertainty))
cat(sprintf("Component 15 - Drywall:      $%.2f\n", drywall_uncertainty))
cat(sprintf("Component 16 - Trim:         $%.2f\n", trim_uncertainty))
cat(sprintf("Component 17 - Paint:        $%.2f\n", paint_uncertainty))
